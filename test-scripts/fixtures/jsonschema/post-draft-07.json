{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/post.json",
  "title": "Post",
  "type": "object",
  "definitions": {
    "Author": {
      "type": "object",
      "title": "Author",
      "properties": {
        "id":   { "type": "integer" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    }
  },
  "properties": {
    "id":      { "type": "integer", "x-primary": true },
    "title":   { "type": "string", "minLength": 1, "maxLength": 200 },
    "content": { "type": "string" },
    "slug":    { "type": "string", "pattern": "^[a-z0-9-]+$", "x-index": { "unique": true } },
    "tags":    { "type": "array", "items": { "type": "string" } },
    "author":  { "$ref": "#/definitions/Author" }
  },
  "required": ["id", "title", "author"]
}
